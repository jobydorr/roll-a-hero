rules_version = '2';

// Roll a Hero — Firestore security rules for character sharing.
//
// Model: campaigns/{campaignId}/characters/{docId}, where docId is
// "<ownerUid>__<charId>" and each doc carries an `ownerUid` field.
//
// Intent (kid-safe family app, anonymous sign-in):
//  - Anyone signed in (everyone is, anonymously) can READ a campaign's characters
//    — that's how the DM sees the whole party. Knowing the campaign code is the
//    practical gate.
//  - You can only CREATE/UPDATE/DELETE a character that belongs to YOU
//    (ownerUid must equal your own uid), so players can't tamper with each
//    other's heroes.
//
// This replaces the temporary "test mode" rules. Paste into
// Firebase console → Firestore Database → Rules → Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    match /campaigns/{campaignId}/characters/{docId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;

      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    // Everything else is closed by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
